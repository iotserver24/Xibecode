{
  "name": "xibecode",
  "version": "0.9.2",
  "description": "AI-powered autonomous coding assistant with WebUI, AI test generation, multi-model support, and plugin system",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "xibecode": "./dist/index.js",
    "xc": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:webui": "cd webui && pnpm install && pnpm build",
    "build:all": "pnpm run build && pnpm run build:webui",
    "dev": "node scripts/dev.mjs",
    "start": "node dist/index.js",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "ui": "pnpm exec tsc && node dist/index.js ui --open",
    "ui:dev": "node scripts/dev.mjs ui",
    "docs:generate": "typedoc --options typedoc.json",
    "docs:watch": "typedoc --options typedoc.json --watch",
    "docs:serve": "npx http-server ./docs/api-generated -p 8080 -o"
  },
  "keywords": [
    "cli",
    "ai",
    "coding",
    "assistant",
    "autonomous",
    "agent",
    "automation",
    "webui",
    "test-generation"
  ],
  "author": "Anish Kumar (R3AP3R editz) <https://github.com/iotserver24>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/iotserver24/xibecode"
  },
  "bugs": {
    "url": "https://github.com/iotserver24/xibecode/issues"
  },
  "homepage": "https://github.com/iotserver24/xibecode#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agent-browser": "^0.25.3",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "conf": "^15.1.0",
    "diff": "^5.1.0",
    "dotenv": "^16.3.1",
    "fast-glob": "^3.3.3",
    "ink": "^6.7.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^13.4.1",
    "marked": "^11.2.0",
    "marked-terminal": "^7.3.0",
    "node-fetch": "^3.3.2",
    "open": "^10.0.0",
    "ora": "^5.4.1",
    "react": "^19.2.4",
    "strip-ansi": "^7.1.0",
    "ts-morph": "^27.0.2",
    "typescript": "^5.3.3",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/diff": "^5.0.8",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.13",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "@modelcontextprotocol/sdk>hono": "4.12.4",
      "@modelcontextprotocol/sdk>@hono/node-server": "1.19.10",
      "@modelcontextprotocol/sdk>express-rate-limit": "8.2.2",
      "path-to-regexp": "8.4.0",
      "@ts-morph/common>minimatch": "10.2.3",
      "vitest>picomatch": "4.0.4",
      "micromatch>picomatch": "2.3.2",
      "tinyglobby>picomatch": "4.0.4"
    }
  },
  "files": [
    "dist",
    "webui-dist",
    "skills",
    "README.md"
  ]
}
