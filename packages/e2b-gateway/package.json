{
  "name": "@xibecode/e2b-gateway",
  "version": "1.3.3",
  "private": true,
  "type": "module",
  "description": "Team-hosted gateway for running XibeCode commands on E2B sandboxes",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "bun --env-file=.env --hot src/index.ts",
    "start": "bun --env-file=.env src/index.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "e2b": "^2.35.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.23.1",
    "typescript": "^5.3.3"
  }
}
