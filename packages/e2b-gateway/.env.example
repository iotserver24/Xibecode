# Copy to `.env` for local dev, or set these in Coolify → Environment variables.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# E2B (required on the server)
# Create at https://e2b.dev/dashboard — stays ONLY on this gateway, not in XibeCode CLI.
# -----------------------------------------------------------------------------
E2B_API_KEY=

# -----------------------------------------------------------------------------
# Gateway auth (strongly recommended in production)
# CLI: xibecode config --set-sandbox-auth-token "<same value>"
# If unset, anyone who can reach the URL can create sandboxes (okay for LAN tests only).
# -----------------------------------------------------------------------------
XIBECODE_GATEWAY_TOKEN=

# -----------------------------------------------------------------------------
# HTTP
# Coolify often injects PORT automatically; default matches Docker EXPOSE.
# -----------------------------------------------------------------------------
PORT=8787

# -----------------------------------------------------------------------------
# Optional: custom E2B sandbox template (passed to Sandbox.create)
# Use your published template ID or alias, e.g. xibecode-full-sandbox
# -----------------------------------------------------------------------------
# XIBECODE_E2B_TEMPLATE=xibecode-full-sandbox

# -----------------------------------------------------------------------------
# Optional: default workspace root for sandbox_full sync/execution.
# CLI can still override per-session.
# -----------------------------------------------------------------------------
# XIBECODE_SANDBOX_WORKSPACE_ROOT=/home/user/workspace
