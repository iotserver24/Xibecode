{
  "name": "xibecode-desktop",
  "version": "1.0.4",
  "description": "XibeCode Desktop - AI-powered coding assistant with file access, shell, and web preview",
  "author": "Anish Kumar (R3AP3R editz) <anish.kumar@example.com>",
  "homepage": "https://github.com/iotserver24/xibecode",
  "repository": {
    "type": "git",
    "url": "https://github.com/iotserver24/xibecode"
  },
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:check": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "pnpm run build && electron-builder",
    "clean": "rm -rf dist release",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "conf": "^15.1.0",
    "framer-motion": "^12.42.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^3.6.0",
    "xibecode-core": "^1.3.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.1.2",
    "electron": "^41.5.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.3.3",
    "vite": "^6.3.3",
    "wait-on": "^8.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
