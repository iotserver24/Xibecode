{
  "name": "@xibecode/hosting",
  "version": "0.1.0",
  "private": true,
  "description": "XibeCode Hosting — sell managed E2B sandboxes with AI + Telegram gateway setup",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && mkdir -p dist/public && cp -r src/public/. dist/public/",
